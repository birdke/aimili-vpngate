# Listen publicly only when the host/cloud firewall restricts TCP 8790 to the
# Hong Kong VPS address. Use 127.0.0.1 behind a TLS reverse proxy or SSH tunnel.
VPNGATE_RELAY_HOST=0.0.0.0
VPNGATE_RELAY_PORT=8790
VPNGATE_RELAY_TOKEN=replace-with-a-long-random-token
VPNGATE_RELAY_ALLOWED_IPS=203.0.113.10

# Fetch at most once every 10 minutes and retain a last-known-good response for
# up to one day when the official API has a temporary outage.
VPNGATE_RELAY_CACHE_TTL=600
VPNGATE_RELAY_STALE_TTL=86400
VPNGATE_RELAY_TIMEOUT=30
